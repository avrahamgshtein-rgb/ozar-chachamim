# Supabase Configuration
# These are the credentials for the אוצר חכמים project
#
# To set up:
# 1. Copy this file: cp .env.example .env.local
# 2. Go to https://app.supabase.com and select your project
# 3. Navigate to Settings > API
# 4. Copy the "Project URL" and paste it below
# 5. Copy the "anon public" key and paste it below
#
# NOTE: For a plain HTML/JS app (no build tooling), use config.example.js instead
# to avoid environment variable issues.
#
# However, if you're planning to migrate to Vite/Next.js/React in the future,
# these environment variables will be used by the build system.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Example values:
# VITE_SUPABASE_URL=https://ulluacifirzywhmzkvkr.supabase.co
# VITE_SUPABASE_ANON_KEY=sb_publishable_ObxKLFsDTE41KoAMfMV1dw_Nu38ZI2C
