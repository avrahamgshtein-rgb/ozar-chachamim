# ============================================================
# OZAR CHACHAMIM — Environment Variables
# Copy this file to .env and fill in your actual values
# ============================================================

# ==================== SUPABASE FRONTEND ====================
# Used by: index.html (client-side, public data only)
# Get these from: https://app.supabase.com → Your Project → Settings > API
# These use the ANON key (read-only public access via RLS)

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your_anon_key_here

# ==================== SUPABASE BACKEND ====================
# Used by: run-enrichment.js (server-side, full access)
# ⚠️ SECURITY: Never expose SERVICE_ROLE_KEY in public code
# Keep this in .env (which is .gitignore'd) — never commit to git

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_service_role_your_secret_key_here

# ==================== GOOGLE DRIVE ====================
# Your Google Drive research folder ID
# How to find: drive.google.com/drive/folders/[THIS_IS_YOUR_ID]

GOOGLE_DRIVE_FOLDER_ID=1_E2VtWpJ6RLyHCxvOV9_NUmIUZkZU3Jc

# ==================== OPTIONAL ====================

NODE_ENV=production
LOG_LEVEL=info

# ============================================================
# SETUP INSTRUCTIONS:
#
# 1. Frontend credentials (for index.html):
#    - Go to: https://app.supabase.com → Your Project
#    - Settings > API
#    - Copy "Project URL" → VITE_SUPABASE_URL
#    - Copy "anon public" key → VITE_SUPABASE_ANON_KEY
#
# 2. Backend credentials (for research enrichment):
#    - Same project, Settings > API
#    - Copy "Service Role Key" → SUPABASE_SERVICE_ROLE_KEY
#    - ⚠️ KEEP THIS SECRET — never commit to git
#
# 3. Google Drive folder:
#    - Share your research folder with service account
#    - See: connectors/GOOGLE_DRIVE_CONNECTOR_SETUP.md
#
# 4. Create .env file:
#    cp .env.example .env
#    # Edit .env and paste your values
#
# 5. Add to .gitignore:
#    echo ".env" >> .gitignore
#
# ============================================================
